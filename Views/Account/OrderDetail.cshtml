@model Projet.Models.Order
@{
    ViewData["Title"] = $"Commande #{Model.Id}";
}

<div class="shop-header">
    <div class="container">
        <h1 class="shop-title">
            <i class="fas fa-box me-2"></i>Commande #@Model.Id
        </h1>
        <p class="shop-subtitle">
            Passée le @Model.CreatedAt.ToString("dd MMMM yyyy à HH:mm")
        </p>
    </div>
</div>

<div class="container py-5">

    <!-- Fil d'ariane -->
    <nav class="mb-4">
        <ol class="breadcrumb-custom">
            <li><a asp-controller="Home" asp-action="Index">Accueil</a></li>
            <li><i class="fas fa-chevron-right"></i></li>
            <li><a asp-controller="Account" asp-action="Orders">Mes commandes</a></li>
            <li><i class="fas fa-chevron-right"></i></li>
            <li class="active">Commande #@Model.Id</li>
        </ol>
    </nav>

    <!-- Statut & Timeline -->
    <div class="order-detail-status-card mb-4">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <div>
                <div class="order-detail-num">Commande #@Model.Id</div>
                <div class="order-detail-date">
                    @Model.CreatedAt.ToString("dd MMMM yyyy à HH:mm")
                </div>
            </div>
            <span class="order-status status-@Model.Status.ToLower().Replace(" ", "") fs-6 px-3 py-2">
                @Model.Status
            </span>
        </div>

        <!-- Timeline -->
        @if (Model.Status != "Annulée")
        {
            <div class="order-timeline order-timeline-large">
                @{
                    var steps = new[] {
                        new { Label = "En attente",     Icon = "fa-clock" },
                        new { Label = "Confirmée",      Icon = "fa-check-circle" },
                        new { Label = "En préparation", Icon = "fa-box" },
                        new { Label = "Expédiée",       Icon = "fa-truck" },
                        new { Label = "Livrée",         Icon = "fa-home" },
                    };
                    var labels = steps.Select(s => s.Label).ToArray();
                    int current = Array.IndexOf(labels, Model.Status);
                }
                @for (int i = 0; i < steps.Length; i++)
                {
                    bool done = i <= current;
                    bool active = i == current;
                    <div class="timeline-step @(done ? "done" : "") @(active ? "active" : "")">
                        <div class="timeline-dot">
                            @if (done && !active)
                            {
                                <i class="fas fa-check"></i>
                            }
                            else
                            {
                                <i class="fas @steps[i].Icon"></i>
                            }
                        </div>
                        <div class="timeline-label">@steps[i].Label</div>
                    </div>
                    @if (i < steps.Length - 1)
                    {
                        <div class="timeline-line @(i < current ? "done" : "")"></div>
                    }
                }
            </div>
        }
        else
        {
            <div class="alert alert-danger rounded-3 d-flex align-items-center gap-2">
                <i class="fas fa-times-circle"></i>
                Cette commande a été annulée.
            </div>
        }
    </div>

    <div class="row g-4">

        <!-- ══ Articles ═══════════════════════ -->
        <div class="col-lg-8">
            <div class="cart-card mb-4">
                <div class="cart-card-header">
                    <h5><i class="fas fa-list me-2"></i>Articles commandés</h5>
                </div>
                @foreach (var item in Model.Items)
                {
                    <div class="cart-item">
                        <div class="cart-item-img">
                            @if (item.Product?.ImageUrl != null)
                            {
                                <img src="@item.Product.ImageUrl"
                                     alt="@item.Product?.Name" />
                            }
                            else
                            {
                                <i class="fas fa-image"></i>
                            }
                        </div>
                        <div class="cart-item-info">
                            <div class="cart-item-name">@item.Product?.Name</div>
                            <div class="cart-item-price">
                                @item.UnitPrice.ToString("0.00") DT / unité
                            </div>
                        </div>
                        <div class="cart-item-qty">
                            <span class="qty-display">×@item.Quantity</span>
                        </div>
                        <div class="cart-item-total">
                            <strong>
                                @((item.UnitPrice * item.Quantity).ToString("0.00")) DT
                            </strong>
                        </div>
                    </div>
                }
            </div>

            <!-- Suivi livraison -->
            @if (!string.IsNullOrEmpty(Model.TrackingNumber))
            {
                <div class="tracking-card">
                    <div class="tracking-header">
                        <i class="fas fa-truck me-2"></i>Suivi de livraison
                    </div>
                    <div class="tracking-body">
                        <div class="tracking-num">
                            Numéro de suivi :
                            <strong>@Model.TrackingNumber</strong>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- ══ Récapitulatif ══════════════════ -->
        <div class="col-lg-4">

            <!-- Résumé financier -->
            <div class="cart-summary mb-4">
                <h5 class="cart-summary-title">
                    <i class="fas fa-receipt me-2"></i>Résumé
                </h5>
                <div class="cart-summary-row">
                    <span>Sous-total</span>
                    <span>
                        @Model.Items.Sum(i => i.UnitPrice * i.Quantity).ToString("0.00") DT
                    </span>
                </div>
                @if (Model.Discount > 0)
                {
                    <div class="cart-summary-row text-success">
                        <span>
                            Réduction
                            @if (!string.IsNullOrEmpty(Model.PromoCodeUsed))
                            {
                                <small>(@Model.PromoCodeUsed)</small>
                            }
                        </span>
                        <span>-@Model.Discount.ToString("0.00") DT</span>
                    </div>
                }
                <hr />
                <div class="cart-summary-total">
                    <span>Total payé</span>
                    <span>@Model.Total.ToString("0.00") DT</span>
                </div>
                <div class="cart-summary-row mt-2">
                    <span>Points gagnés</span>
                    <span class="text-gold">
                        +@((int)(Model.Total * 10)) pts ⭐
                    </span>
                </div>
            </div>

            <!-- Infos livraison -->
            <div class="order-info-card mb-4">
                <div class="order-info-title">
                    <i class="fas fa-map-marker-alt me-2"></i>Adresse de livraison
                </div>
                <div class="order-info-value">@Model.ShippingAddress</div>
            </div>

            <!-- Infos client -->
            <div class="order-info-card mb-4">
                <div class="order-info-title">
                    <i class="fas fa-user me-2"></i>Client
                </div>
                <div class="order-info-value">@Model.CustomerName</div>
                <div class="order-info-sub">@Model.CustomerEmail</div>
            </div>

            <!-- Actions -->
            <div class="d-flex flex-column gap-2">
                <a asp-controller="Account" asp-action="Orders"
                       class="btn-filter-reset text-center">
                    <i class="fas fa-arrow-left me-2"></i>Retour aux commandes
                </a>
                @if (Model.Status == "En attente")
                {
                    <form asp-action="CancelOrder" method="post"
                          onsubmit="return confirm('Confirmer l\'annulation de cette commande ?')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn-filter-reset text-center w-100"
                                style="color:#c0392b; border-color:#c0392b">
                            <i class="fas fa-times me-2"></i>Annuler la commande
                        </button>
                    </form>
                }
                else if (Model.Status == "Annulée")
                {
                    <div class="text-center p-3 rounded-3"
                         style="background:#fde8e8; color:#c0392b; font-size:0.88rem">
                        <i class="fas fa-ban me-2"></i>Cette commande a été annulée.
                    </div>
                }
                else
                {
                    <div class="text-center p-3 rounded-3"
                         style="background:#fff3cd; color:#856404; font-size:0.88rem">
                        <i class="fas fa-lock me-2"></i>
                        Commande en cours — annulation impossible.
                    </div>
                }
            </div>
        </div>
    </div>
</div>