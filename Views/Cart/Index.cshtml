@model IEnumerable<Projet.Models.CartItem>
@{
    ViewData["Title"] = "Mon Panier";
    decimal total = ViewBag.Total ?? 0m;
    int count = ViewBag.Count ?? 0;
    string? promoCode = Context.Session.GetString("PromoCode");
    string? promoType = Context.Session.GetString("PromoType");
    int promoValue = Context.Session.GetInt32("PromoValue") ?? 0;
    decimal discount = 0;
    if (promoType == "Percentage") discount = total * promoValue / 100;
    if (promoType == "FixedAmount") discount = promoValue;
    decimal finalTotal = total - discount;
}

<!-- Header -->
<div class="shop-header">
    <div class="container">
        <h1 class="shop-title">
            <i class="fas fa-shopping-bag me-2"></i>Mon Panier
        </h1>
        <p class="shop-subtitle">@count article(s) dans votre panier</p>
    </div>
</div>

<div class="container py-5">
    @if (Model.Any())
    {
        <div class="row g-4">

            <!-- ══ Articles ═══════════════════════ -->
            <div class="col-lg-8">
                <div class="cart-card">
                    <div class="cart-card-header">
                        <h5><i class="fas fa-list me-2"></i>Articles</h5>
                        <a asp-action="Clear" class="cart-clear-btn"
                               onclick="return confirm('Vider le panier ?')">
                            <i class="fas fa-trash me-1"></i>Tout supprimer
                        </a>
                    </div>
                    @foreach (var item in Model)
                    {
                        <div class="cart-item">
                            <div class="cart-item-img">
                                @if (item.ImageUrl != null)
                                {
                                    <img src="@item.ImageUrl" alt="@item.ProductName" />
                                }
                                else
                                {
                                    <i class="fas fa-image"></i>
                                }
                            </div>
                            <div class="cart-item-info">
                                <div class="cart-item-name">@item.ProductName</div>
                                <div class="cart-item-price">
                                    @item.UnitPrice.ToString("0.00") DT / unité
                                </div>
                            </div>
                            <div class="cart-item-qty">
                                <form asp-action="UpdateQuantity" method="post"
                                      class="qty-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId"
                                           value="@item.ProductId" />
                                    <div class="qty-control">
                                        <button type="submit" name="quantity"
                                                value="@(item.Quantity - 1)"
                                                class="qty-btn">
                                            −
                                        </button>
                                        <span class="qty-display">@item.Quantity</span>
                                        <button type="submit" name="quantity"
                                                value="@(item.Quantity + 1)"
                                                class="qty-btn">
                                            +
                                        </button>
                                    </div>
                                </form>
                            </div>
                            <div class="cart-item-total">
                                <strong>@item.Total.ToString("0.00") DT</strong>
                            </div>
                            <a asp-action="Remove"
                                   asp-route-productId="@item.ProductId"
                                   class="cart-item-remove">
                                <i class="fas fa-times"></i>
                            </a>
                        </div>
                    }
                </div>

                <!-- Code promo -->
                <div class="cart-card mt-3">
                    <div class="cart-card-header">
                        <h5><i class="fas fa-ticket-alt me-2"></i>Code promo</h5>
                    </div>
                    <div class="p-4">
                        @if (!string.IsNullOrEmpty(promoCode))
                        {
                            <div class="promo-applied">
                                <i class="fas fa-check-circle me-2"></i>
                                Code <strong>@promoCode</strong> appliqué —
                                @(promoType == "Percentage"
                                    ? $"-{promoValue}%"
                                    : $"-{promoValue} DT")
                                <a asp-action="RemovePromo" class="promo-remove ms-3">
                                    <i class="fas fa-times"></i> Retirer
                                </a>
                            </div>
                        }
                        else
                        {
                            <form asp-action="ApplyPromo" method="post">
                                @Html.AntiForgeryToken()
                                <div class="d-flex gap-2">
                                    <input type="text" name="code"
                                           class="auth-input"
                                           placeholder="Entrez votre code promo"
                                           required />
                                    <button type="submit" class="btn-filter-apply"
                                            style="max-width:140px; white-space:nowrap">
                                        <i class="fas fa-tag me-1"></i>Appliquer
                                    </button>
                                </div>
                            </form>
                        }
                    </div>
                </div>

                <div class="mt-3">
                    <a asp-controller="Shop" asp-action="Index"
                           class="btn-link-rose">
                        <i class="fas fa-arrow-left me-2"></i>
                        Continuer mes achats
                    </a>
                </div>
            </div>

            <!-- ══ Récapitulatif ══════════════════ -->
            <div class="col-lg-4">
                <div class="cart-summary">
                    <h5 class="cart-summary-title">
                        <i class="fas fa-receipt me-2"></i>Récapitulatif
                    </h5>

                    <div class="cart-summary-row">
                        <span>Sous-total</span>
                        <span>@total.ToString("0.00") DT</span>
                    </div>
                    <div class="cart-summary-row">
                        <span>Livraison</span>
                        <span class="text-success">
                            @(total >= 100 ? "Gratuite" : "7.00 DT")
                        </span>
                    </div>
                    @if (discount > 0)
                    {
                        <div class="cart-summary-row text-success">
                            <span>Réduction (@promoCode)</span>
                            <span>-@discount.ToString("0.00") DT</span>
                        </div>
                    }
                    <div class="cart-summary-row">
                        <span>Points à gagner</span>
                        <span class="text-gold">
                            +@((int)(finalTotal * 10)) pts
                        </span>
                    </div>
                    <hr />
                    <div class="cart-summary-total">
                        <span>Total</span>
                        <span>
                            @((finalTotal + (total >= 100 ? 0 : 7)).ToString("0.00")) DT
                        </span>
                    </div>

                    <a asp-action="Checkout" class="cart-checkout-btn">
                        <i class="fas fa-lock me-2"></i>
                        Passer la commande
                    </a>

                    <div class="cart-guarantees">
                        <div class="cart-guarantee">
                            <i class="fas fa-shield-alt"></i>
                            Paiement sécurisé
                        </div>
                        <div class="cart-guarantee">
                            <i class="fas fa-truck"></i>
                            Livraison rapide
                        </div>
                        <div class="cart-guarantee">
                            <i class="fas fa-undo"></i>
                            Retour 30 jours
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="cart-empty">
            <i class="fas fa-shopping-bag"></i>
            <h4>Votre panier est vide</h4>
            <p>Découvrez nos produits et ajoutez-les à votre panier.</p>
            <a asp-controller="Shop" asp-action="Index"
                   class="btn-filter-apply" style="max-width:220px; margin:0 auto">
                <i class="fas fa-store me-2"></i>Découvrir la boutique
            </a>
        </div>
    }
</div>