<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin Handmade with Love</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-body">

    <div class="admin-layout">

        <!-- ══ SIDEBAR ══════════════════════════ -->
        <aside class="admin-sidebar" id="adminSidebar">
            <div class="admin-logo">
                <i class="fas fa-gem me-2"></i>
                <span>Handmade with Love</span>
                <small>Admin</small>
            </div>

            <nav class="admin-nav">
                <div class="admin-nav-section">Général</div>
                <a asp-controller="Admin" asp-action="Index"
                       class="admin-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    <i class="fas fa-tachometer-alt"></i>
                    <span>Tableau de bord</span>
                </a>

                <div class="admin-nav-section">Catalogue</div>
                <a asp-controller="Admin" asp-action="Products"
                       class="admin-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Products" ? "active" : "")">
                    <i class="fas fa-box"></i>
                    <span>Produits</span>
                </a>
                <a asp-controller="Admin" asp-action="Categories"
                       class="admin-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Categories" ? "active" : "")">
                    <i class="fas fa-tags"></i>
                    <span>Catégories</span>
                </a>

                <div class="admin-nav-section">Ventes</div>
                <a asp-controller="Admin" asp-action="Orders"
                       class="admin-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Orders" ? "active" : "")">
                    <i class="fas fa-shopping-cart"></i>
                    <span>Commandes</span>
                </a>
                <a asp-controller="Admin" asp-action="PromoCodes"
                       class="admin-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "PromoCodes" ? "active" : "")">
                    <i class="fas fa-ticket-alt"></i>
                    <span>Codes promo</span>
                </a>

                <div class="admin-nav-section">Clients</div>
                <a asp-controller="Admin" asp-action="Users"
                       class="admin-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")">
                    <i class="fas fa-users"></i>
                    <span>Utilisateurs</span>
                </a>
                <a asp-controller="Admin" asp-action="Reviews"
                       class="admin-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Reviews" ? "active" : "")">
                    <i class="fas fa-star"></i>
                    <span>Avis clients</span>
                </a>

                <div class="admin-nav-section">Compte</div>
                <a asp-controller="Home" asp-action="Index" class="admin-nav-link">
                    <i class="fas fa-store"></i>
                    <span>Voir la boutique</span>
                </a>
                <a asp-controller="Account" asp-action="Logout" class="admin-nav-link text-danger-link">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Déconnexion</span>
                </a>
            </nav>
        </aside>

        <!-- ══ CONTENU ═══════════════════════════ -->
        <div class="admin-main">

            <!-- Topbar -->
            <header class="admin-topbar">
                <button class="admin-toggle" onclick="toggleSidebar()">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="admin-topbar-title">@ViewData["Title"]</div>
                <div class="admin-topbar-right">
                    <span class="admin-topbar-user">
                        <div class="admin-user-avatar">
                            @(Context.Session.GetString("UserName")?.Substring(0, 1) ?? "A")
                        </div>
                        @Context.Session.GetString("UserName")
                    </span>
                </div>
            </header>

            <!-- Alertes -->
            @if (TempData["Success"] != null)
            {
                <div class="admin-alert admin-alert-success">
                    <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                    <button onclick="this.parentElement.remove()" class="admin-alert-close">×</button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="admin-alert admin-alert-error">
                    <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                    <button onclick="this.parentElement.remove()" class="admin-alert-close">×</button>
                </div>
            }

            <!-- Page content -->
            <div class="admin-content">
                @RenderBody()
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
        document.getElementById('adminSidebar').classList.toggle('collapsed');
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>